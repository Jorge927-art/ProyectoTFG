# ======================================================
# Backend local env template (do not commit real secrets)
# ======================================================
# Usage:
# 1) Copy this file to .env.properties or .env.local
# 2) Set your real password
# 3) Run: mvn spring-boot:run

# -------------------------
# Profile (optional)
# -------------------------
# app defaults to dev profile if not set
SPRING_PROFILES_ACTIVE=dev

# -------------------------
# PostgreSQL connection
# -------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/gestion-cursos-backend
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=replace_with_real_password

# -------------------------
# JPA/Hibernate
# -------------------------
# dev: update | prod: validate (recommended)
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

# -------------------------
# Logging
# -------------------------
LOGGING_LEVEL_ORG_HIBERNATE_ORM_JDBC_BIND=trace
